# Production (HTTPS required when admin is on https://admin.jetjams.net)
# Uses Vercel rewrites to proxy /api/* → EC2 backend (avoids mixed content)
REACT_APP_BASE_URL=/api
REACT_APP_IMAGE_ENDPOINT=/
REACT_APP_SITE_URL=https://www.jetjams.net

